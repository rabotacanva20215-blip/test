{
  "manifest_version": 3,
  "name": "KirillTube — YouTube Intelligence",
  "short_name": "KirillTube",
  "version": "1.2.0",
  "description": "Поиск видео-близнецов, похожих каналов, ДНК канала, Content Gap, тренды и идеи прямо на YouTube.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://www.googleapis.com/*",
    "https://youtube.googleapis.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "KirillTube",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
